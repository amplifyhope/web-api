{
  "name": "amplify-hope-api",
  "version": "1.7.1",
  "description": "NodeJS API backend for amplify hope website",
  "main": "src/index.ts",
  "author": "Anthony Giannell",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write .",
    "lint": "eslint src",
    "rebuild-db": "docker compose stop db; docker compose rm -f db; docker compose up -d",
    "start": "NODE_OPTIONS='--unhandled-rejections=warn' ts-node src/index.ts",
    "start:dev": "NODE_OPTIONS='--unhandled-rejections=warn' ts-node-dev src/index.ts",
    "test:unit": "NODE_ENV=development ts-mocha '**/*.unit.ts'",
    "typecheck": "tsc --noEmit",
    "version": "echo $npm_package_version"
  },
  "dependencies": {
    "@sentry/node": "^10.62.0",
    "@sentry/profiling-node": "^10.62.0",
    "camelcase-keys": "^7.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "ramda": "^0.32.0",
    "resend": "^6.16.0",
    "snakecase-keys": "^8.1.0",
    "stripe": "^17.7.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chai": "^4.3.11",
    "@types/cors": "^2.8.19",
    "@types/eslint": "^8.56.10",
    "@types/eslint-plugin-prettier": "^3.1.3",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22",
    "@types/pg": "^8.15.6",
    "@types/prettier": "^2.7.1",
    "@types/ramda": "^0.31.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "chai": "^4.5.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "mocha": "^11.7.6",
    "prettier": "^3.7.4",
    "ts-mocha": "^10.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.62.0"
  },
  "engines": {
    "node": ">=24"
  },
  "resolutions": {
    "brace-expansion": "^1.1.13",
    "diff": "^5.2.2",
    "flatted": "^3.4.2",
    "glob": "^10.5.0",
    "js-yaml": "^4.2.0",
    "minimatch": "^9.0.6",
    "path-to-regexp": "0.1.13",
    "picomatch": "^2.3.2",
    "qs": "^6.14.2",
    "serialize-javascript": "^7.0.5"
  }
}
